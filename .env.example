# Frontend env vars — set these in Vercel project settings for production.
# Locally, copy this file to `.env` and fill in real values.

# Public base path the build is served under.
#   GitHub Pages (default):  /Coffeshop-E-Commerce-Website/
#   Vercel / custom domain:  /
VITE_BASE=/

# Cloudflare Worker URL (set after `wrangler deploy`).
# The AI assistant widget POSTs to `${VITE_WORKER_URL}/api/chat`,
# and the cart's "save my order" flow POSTs to `${VITE_WORKER_URL}/api/orders`.
# Example: https://coffee-luxe-api.your-name.workers.dev
VITE_WORKER_URL=
